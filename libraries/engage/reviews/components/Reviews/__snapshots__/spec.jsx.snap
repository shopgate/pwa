exports[`<Reviews /> should render when no reviews and rating given 1`] = `
<Provider
  store={
    {
      "clearActions": [Function],
      "dispatch": [Function],
      "getActions": [Function],
      "getState": [Function],
      "replaceReducer": [Function],
      "subscribe": [Function],
    }
  }
>
  <Connect(Reviews)
    productId="foo"
  >
    <Reviews
      dispatch={[Function]}
      productActive={true}
      productId="foo"
      reviews={null}
    >
      <SurroundPortals
        portalName="product.reviews"
        portalProps={
          {
            "productId": "foo",
          }
        }
      >
        <div
          className="tss-11aldym-container engage__reviews__reviews"
          data-test-id="reviewSection"
        >
          <Header
            productId="foo"
          >
            <div />
          </Header>
          <List
            productId="foo"
            reviews={null}
          />
          <Connect(AllReviewsLink)
            productId="foo"
          >
            <AllReviewsLink
              count={null}
              dispatch={[Function]}
              productId="foo"
            />
          </Connect(AllReviewsLink)>
          <ReviewsInfo />
        </div>
      </SurroundPortals>
    </Reviews>
  </Connect(Reviews)>
</Provider>
`;
