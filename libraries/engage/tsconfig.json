{
  "compilerOptions": {
    "target": "es2019",
    "lib": ["DOM", "ES2019"],
    "module": "esnext",
    "moduleResolution": "node",
    "jsx": "react-jsx",

    "strict": true,
    "isolatedModules": true,
    "esModuleInterop": true,

    "allowJs": true,
    "checkJs": false,
    "noEmit": true
  }
}

