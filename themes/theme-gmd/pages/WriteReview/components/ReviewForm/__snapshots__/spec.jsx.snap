                                  className="tss-1n8b10t-root common__icon"
                                  dangerouslySetInnerHTML={
                                    {
                                      "__html": "<path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>",
                                    }
                                  }
                                  style={
                                    {
                                      "fill": undefined,
                                      "fontSize": "2.3em",
                                    }
                                  }
                                  viewBox="0 0 24 24"
                                  xmlns="http://www.w3.org/2000/svg"
                                />
                              </Icon>
                            </Star>
                          </div>
                          <div
                            aria-label="reviews.press_to_rate_with_x_stars"
                            className="tss-14pcrjo-icon tss-1i3xs02-iconGapLarge"
