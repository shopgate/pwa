        >
          <section
            className="tss-15hbfuu-container"
            data-test-id="reviewForm"
          >
            <form
              onSubmit={[Function]}
            >
              <RatingScale
                errorText=""
                onChange={[Function]}
                value={100}
              >
                <div
                  className="tss-xs3srv-ratingLine"
                >
                  <Text
                    className="tss-1je746r-label"
                    string="reviews.review_form_rate"
                  >
                    reviews.review_form_rate
                  </Text>
                  <span
                    className="tss-1w2r5h9-scale"
                  >
                    <RatingStars
                      className=""
                      display="large"
                      errorText=""
                      isSelectable={true}
                      onSelection={[Function]}
                      value={100}
                    >
                      <div
                        aria-label="reviews.rating_stars"
                        className="tss-1tckjm8-container ui-shared__rating-stars"
                        data-test-id="ratedStars: 5"
                      >
                        <div
                          className="tss-170uo4n-emptyStars rating-stars-empty"
                        >
                          <div
                            aria-label="reviews.press_to_rate_with_x_stars"
                            className="tss-14pcrjo-icon tss-1i3xs02-iconGapLarge"
                            key="1"
                            onClick={[Function]}
                            role="button"
                          >
                            <Star
                              size="2.3em"
                            >
                              <Icon
                                content="<path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>"
                                size="2.3em"
                              >
